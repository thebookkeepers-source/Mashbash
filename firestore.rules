rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() ? userDoc().data.role : null;
    }

    function isOwner() {
      return role() == 'owner';
    }

    function hasRight(right) {
      return isOwner() || userDoc().data.rights[right] == true;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isOwner());
      allow create: if signedIn() && (
        (request.auth.uid == userId && request.resource.data.role == 'customer') ||
        isOwner()
      );
      allow update: if signedIn() && (
        isOwner() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role && request.resource.data.rights == resource.data.rights)
      );
      allow delete: if isOwner();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if signedIn() && hasRight('manageMenu');
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if signedIn() && hasRight('manageDeals');
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && role() == 'customer'
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'received';
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        hasRight('viewOrders')
      );
      allow update: if signedIn() && hasRight('updateOrderStatus')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if isOwner();
    }

    match /appConfig/{document} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOwner();
    }
  }
}
